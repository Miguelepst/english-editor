# ==============================================================================
# Makefile.security - Pipeline de DevSecOps Aislado
# ==============================================================================
.PHONY: install-tools secrets sast sca verify-all

# ------------------------------------------------------------------------------
# PREPARACIÓN DEL ENTORNO
# ------------------------------------------------------------------------------
install-tools:
	@echo "📦 Instalando herramientas de seguridad (Gitleaks, Bandit, Pip-Audit)..."
	@if ! command -v gitleaks >/dev/null 2>&1; then \
		wget -qO- https://github.com/gitleaks/gitleaks/releases/download/v8.18.2/gitleaks_8.18.2_linux_x64.tar.gz | tar xz -C /usr/local/bin gitleaks; \
	fi
	pip install bandit pip-audit -q
	@echo "✅ Herramientas instaladas correctamente."

# ------------------------------------------------------------------------------
# Fase 1: SECRETS (Evita catástrofes inmediatas)
# ------------------------------------------------------------------------------
secrets:
	@echo "🔐 [Step 1] Escaneando secretos con Gitleaks..."
	gitleaks detect -v --source . --no-git

# ------------------------------------------------------------------------------
# Fase 2: SAST (Corrige errores lógicos del desarrollador)
# ------------------------------------------------------------------------------
sast:
	@echo "🧠 [Step 2] Ejecutando análisis SAST con Bandit sobre src/..."
	python -m bandit -r src/ -ll -i

# ------------------------------------------------------------------------------
# Fase 3: SCA (Auditoría de Dependencias de Terceros)
# ------------------------------------------------------------------------------
sca:
	@echo "📦 [Step 3] Escaneando dependencias vulnerables con pip-audit..."
	# pip-audit revisa los paquetes instalados en el entorno actual
	# ignoramos errores si hay paquetes del sistema de Colab que no se pueden auditar fácilmente
	python -m pip_audit || echo "⚠️ Revisa los avisos de arriba. Actualiza las librerías vulnerables si es necesario."

# ------------------------------------------------------------------------------
# VERIFICACIÓN COMPLETA DE SEGURIDAD
# ------------------------------------------------------------------------------
verify-all: secrets sast sca
	@echo "✅ VALIDACIÓN DE SEGURIDAD (Fases 1, 2 y 3) EXITOSA."
